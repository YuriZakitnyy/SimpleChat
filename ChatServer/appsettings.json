{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Firebase": {
    "CredentialPath": "firebase-credentials.json"
  },
  "DeviceStorage": {
    "FilePath": "/var/data/devices.json"
  },
  "MessageStorage": {
    "Directory": "/var/data/messages"
  }
}